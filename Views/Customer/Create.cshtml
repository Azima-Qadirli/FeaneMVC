@using Feane.ViewModels.Customers
@model CustomersCreateVM

@{
    Layout = "_Layout";
}

<section class="book_section layout_padding">
    <div class="container">

        <div class="heading_container heading_center mb-5 text-center">
            <h2 class="font-weight-bold" style="color: yellow;">Give your opinion about our restaurant</h2>
        </div>

        <div class="row justify-content-center">
            <div class="col-md-6 border p-4 rounded bg-light shadow-sm">

                <form method="post" asp-action="Create" enctype="multipart/form-data">

                    <div class="form-group mb-3">
                        <label asp-for="Name" class="font-weight-bold text-dark">Your Name</label>
                        <input asp-for="Name" class="form-control" placeholder="Enter your name" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Comment" class="font-weight-bold text-dark">Comment</label>
                        <textarea asp-for="Comment" class="form-control" rows="4" placeholder="Share your idea..."></textarea>
                        <span asp-validation-for="Comment" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="ImageName" class="font-weight-bold text-dark">Image</label>
                        <input asp-for="ImageName" type="file" class="form-control" />
                        <span asp-validation-for="ImageName" class="text-danger"></span>
                    </div>

                    <div class="btn_box">
                        <button type="submit" class="btn text-white w-100 py-2 font-weight-bold" style="background-color: #ffbe33; border: none; border-radius: 5px;">
                           Submit
                        </button>
                    </div>

                </form>

            </div>
        </div>
    </div>
</section>