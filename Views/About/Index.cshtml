@using Feane.ViewModels.Appaeareance
@model List<AppeareanceGetVM>﻿
<!-- about section -->

<section class="about_section layout_padding">
    <div class="container  ">
        @foreach(var item in Model)
        {
            <div class="row">
                <div class="col-md-6 ">
                    <div class="img-box">
                        <img src="~/images/@item.ImageName" alt="">
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="detail-box">
                        <div class="heading_container">
                            <h2>
                                @item.Title
                            </h2>
                        </div>
                        <p>
                            @item.Description
                        </p>
                    </div>
                </div>
            </div>
        }
        
    </div>
</section>

<!-- end about section -->

 