@using Feane.ViewModels.Customers
@model List<CustomersGetVM>

<div class="container">
    <div class="row">

        <table class="table">

            <thead>
                <tr>
                    <th scope="col">Id</th>
                    <th scope="col">Name</th>
                    <th scope="col">Image</th>
                    <th scope="col">Comment</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>

                        <td>@item.Name</td>

                        <td>
                            <img src="~/images/@item.ImageName" width="100" />
                        </td>

                        <td>@item.Comment</td>

                        <td>
                            <a asp-action="Update"
                               asp-route-id="@item.Id"
                               class="btn btn-warning">
                                Update
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-danger">
                                Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>
</div>