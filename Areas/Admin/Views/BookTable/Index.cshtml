@using Feane.ViewModels.BookTable
@model List<BookTableGetVM>

<div class="container mt-4">
    <div class="row mb-3">
    </div>
    <div class="row">
        <div class="col-12">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col">PhoneNumber</th>
                        <th scope="col">Email</th>
                        <th scope="col">Date</th>
                        <th scope="col">PersonNumber</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var table in Model)
                    {
                        <tr>
                            <td>@table.Name</td>
                            <td>@table.PhoneNumber</td>
                            <td>@table.Email</td>
                            <td>@table.Date</td>
                            <td>@table.PersonNumber</td>
                            <td>
                                <a asp-action="Delete" asp-route-id="@table.Id" class="btn btn-danger btn-sm">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>