@model Feane.ViewModels.Account.LoginVM
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8">
    <title>Feane - Gourmet Admin Panel</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght=600&family=Poppins:wght=300;400;600&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
            :root {
                --primary: #ff3e3e;
                --primary-glow: rgba(255, 62, 62, 0.6);
                --bg-dark: #0f0808;
            }

            body {
                background-color: var(--bg-dark);
                font-family: 'Poppins', sans-serif;
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0;
                overflow: hidden;
                position: relative;
            }

            #gourmet-canvas {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                z-index: 1;
            }

            .login-container {
                width: 100%;
                max-width: 430px;
                z-index: 10;
                padding: 20px;
                animation: formReveal 1.2s cubic-bezier(0.16, 1, 0.3, 1);
            }

            .login-card {
                background: rgba(18, 10, 10, 0.85);
                backdrop-filter: blur(35px);
                -webkit-backdrop-filter: blur(35px);
                border: 1px solid rgba(255, 62, 62, 0.35);
                border-radius: 35px;
                padding: 55px 45px;
                box-shadow: 0 40px 100px rgba(0, 0, 0, 0.85), inset 0 1px 3px rgba(255, 255, 255, 0.12);
            }

            .brand-logo h3 {
                font-family: 'Playfair Display', serif;
                color: #fff;
                font-size: 2.5rem;
                margin: 0;
            }

                .brand-logo h3 span {
                    color: var(--primary);
                    text-shadow: 0 0 20px var(--primary-glow);
                }

            .form-floating > .form-control {
                background: rgba(0, 0, 0, 0.55) !important;
                border: 1px solid rgba(255, 62, 62, 0.25);
                color: #fff !important;
                border-radius: 16px;
            }

                .form-floating > .form-control:focus {
                    border-color: var(--primary);
                    box-shadow: 0 0 15px rgba(255, 62, 62, 0.35);
                }

            .form-floating > label {
                color: #caa0a0;
            }

            .form-floating > .form-control:focus ~ label, .form-floating > .form-control:not(:placeholder-shown) ~ label {
                color: var(--primary);
            }

            .btn-login {
                background: linear-gradient(135deg, rgba(255, 62, 62, 0.2), rgba(255, 62, 62, 0.4));
                border: 1px solid var(--primary);
                color: #fff;
                border-radius: 16px;
                font-weight: 500;
                letter-spacing: 1px;
                transition: 0.3s;
            }

                .btn-login:hover {
                    background: var(--primary);
                    color: #fff;
                    font-weight: 600;
                    box-shadow: 0 0 30px var(--primary);
                    transform: translateY(-2px);
                }

            .text-danger ul {
                list-style: none;
                padding: 10px;
                color: #ff6b6b;
                background: rgba(255, 107, 107, 0.1);
                border-radius: 10px;
                font-size: 0.9rem;
            }

            @@keyframes formReveal {
                from {
                    opacity: 0;
                    transform: scale(0.95) translateY(40px);
                }

                to {
                    opacity: 1;
                    transform: scale(1) translateY(0);
                }
            }
    </style>
</head>
<body>

    <canvas id="gourmet-canvas"></canvas>

    <div class="login-container">
        <div class="login-card">
            <div class="brand-logo text-center mb-4">
                <h3><i class="fas fa-utensils me-2 text-primary" style="font-size: 2rem;"></i><span>Feane</span></h3>
                <p class="text-muted small mt-2" style="letter-spacing: 3px; color: #e2c0c0 !important;">RESTORAN IDARƏETMƏSİ</p>
            </div>

            <form asp-area="Admin" asp-controller="Account" asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Email" class="form-control" id="floatingInput" placeholder="Email" autocomplete="off">
                    <label for="floatingInput">Email</label>
                </div>

                <div class="form-floating mb-4">
                    <input asp-for="Password" type="password" class="form-control" id="floatingPassword" placeholder="Şifrə">
                    <label for="floatingPassword">Şifrə</label>
                </div>

                <button type="submit" class="btn btn-login w-100 py-3">GİRİŞ ET</button>
            </form>
        </div>
    </div>

    <script>
            const canvas = document.getElementById('gourmet-canvas');
            const ctx = canvas.getContext('2d');

            let w = canvas.width = window.innerWidth;
            let h = canvas.height = window.innerHeight;

            window.addEventListener('resize', () => {
                w = canvas.width = window.innerWidth;
                h = canvas.height = window.innerHeight;
            });

            // 🌟 Çeşid artırıldı: Restoran, kafe, şirniyyat və bar elementlərinin hamısı bir arada
            const foodIcons = [
                "\uf818", // 🍔 Burger
                "\uf817", // 🍕 Pizza
                "\uf7ec", // 🍟 Fri
                "\uf561", // 🍷 Şərab
                "\uf0f5", // 🍽️ Boşqab
                "\uf66d", // 👨‍🍳 Aşpaz papağı
                "\uf06c", // 🍃 Nanə
                "\uf7a2", // 🐟 Balıq
                "\uf0f4", // ☕ Qəhvə fincanı
                "\uf810", // 🍦 Dondurma
                "\uf79f", // 🧀 Pendir dilimi
                "\uf000", // 🍸 Martini bokalı
                "\uf820"  // 🥗 Salat boşqabı
            ];

            const items = [];
            const dots = []; // ✨ Boşluqları dolduracaq işıq tozcuqları
            const itemCount = 110; // Əsas böyük obyektlər
            const dotCount = 80;   // Kiçik işıq nöqtələri (Cəmi 190 aktiv obyekt!)

            const mouse = { x: null, y: null, radius: 240 };
            window.addEventListener('mousemove', (e) => { mouse.x = e.clientX; mouse.y = e.clientY; });
            window.addEventListener('mouseout', () => { mouse.x = null; mouse.y = null; });

            // Əsas Restoran Obyektləri Sinfi
            class FoodItem {
                constructor() {
                    this.reset();
                    this.y = Math.random() * h;
                }

                reset() {
                    this.x = Math.random() * w;
                    this.y = h + Math.random() * 150;
                    this.icon = foodIcons[Math.floor(Math.random() * foodIcons.length)];
                    this.fontSize = Math.random() * 22 + 15;
                    this.vx = (Math.random() - 0.5) * 0.9;
                    this.vy = -(this.fontSize * 0.05 + Math.random() * 0.5);
                    this.angle = Math.random() * Math.PI * 2;
                    this.spinSpeed = (Math.random() - 0.5) * 0.025;
                    this.alpha = (this.fontSize / 37) * (Math.random() * 0.28 + 0.22);
                }

                update() {
                    this.x += this.vx;
                    this.y += this.vy;
                    this.angle += this.spinSpeed;

                    if (mouse.x !== null && mouse.y !== null) {
                        let dx = this.x - mouse.x;
                        let dy = this.y - mouse.y;
                        let dist = Math.sqrt(dx * dx + dy * dy);
                        if (dist < mouse.radius) {
                            let force = (mouse.radius - dist) / mouse.radius;
                            this.x += (dx / dist) * force * 6;
                            this.y += (dy / dist) * force * 6;
                        }
                    }

                    if (this.y < -50 || this.x < -50 || this.x > w + 50) {
                        this.reset();
                    }
                }

                draw() {
                    ctx.save();
                    ctx.translate(this.x, this.y);
                    ctx.rotate(this.angle);
                    ctx.shadowBlur = 10;
                    ctx.shadowColor = 'rgba(255, 62, 62, 0.45)';
                    ctx.fillStyle = `rgba(255, 95, 95, ${this.alpha})`;
                    ctx.font = `900 ${this.fontSize}px "Font Awesome 6 Free"`;
                    ctx.textAlign = "center";
                    ctx.textBaseline = "middle";
                    ctx.fillText(this.icon, 0, 0);
                    ctx.restore();
                }
            }

            // Boşluqları dolduran İşıq Tozcuqları Sinfi
            class GlowDot {
                constructor() {
                    this.reset();
                    this.y = Math.random() * h;
                }
                reset() {
                    this.x = Math.random() * w;
                    this.y = h + Math.random() * 50;
                    this.r = Math.random() * 2.5 + 1;
                    this.vy = -(Math.random() * 0.4 + 0.2);
                    this.vx = (Math.random() - 0.5) * 0.3;
                    this.alpha = Math.random() * 0.4 + 0.2;
                }
                update() {
                    this.y += this.vy;
                    this.x += this.vx;
                    if (this.y < -10 || this.x < -10 || this.x > w + 10) {
                        this.reset();
                    }
                }
                draw() {
                    ctx.beginPath();
                    ctx.fillStyle = `rgba(255, 120, 120, ${this.alpha})`;
                    ctx.shadowBlur = 6;
                    ctx.shadowColor = 'rgba(255, 62, 62, 0.6)';
                    ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2);
                    ctx.fill();
                }
            }

            // Obyektləri massivə doldur
            for (let i = 0; i < itemCount; i++) items.push(new FoodItem());
            for (let i = 0; i < dotCount; i++) dots.push(new GlowDot());

            // Fon Duman Buludları
            const steamClouds = [];
            for (let i = 0; i < 12; i++) {
                steamClouds.push({
                    x: Math.random() * w, y: Math.random() * h,
                    vx: (Math.random() - 0.5) * 0.25, vy: -(Math.random() * 0.25 + 0.1),
                    r: Math.random() * 380 + 220,
                    color: i % 2 === 0 ? 'rgba(255, 62, 62, 0.04)' : 'rgba(255, 130, 40, 0.025)'
                });
            }

            function animate() {
                ctx.fillStyle = '#0f0808';
                ctx.fillRect(0, 0, w, h);
                ctx.shadowBlur = 0;

                // 1. Duman Buludları (Arxa fon qatı)
                steamClouds.forEach(s => {
                    s.x += s.vx; s.y += s.vy;
                    if (s.y < -s.r) s.y = h + s.r;
                    if (s.x < -s.r || s.x > w + s.r) s.vx *= -1;

                    let g = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, s.r);
                    g.addColorStop(0, s.color);
                    g.addColorStop(1, 'rgba(15, 8, 8, 0)');
                    ctx.fillStyle = g;
                    ctx.beginPath(); ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2); ctx.fill();
                });

                // 2. İşıq Tozcuqları (Orta qat - boşluq dolduranlar)
                dots.forEach(dot => {
                    dot.update();
                    dot.draw();
                });

                // 3. Əsas İkonlar (Ön qat - hərəkətli menyu)
                items.forEach(item => {
                    item.update();
                    item.draw();
                });

                requestAnimationFrame(animate);
            }

            document.fonts.ready.then(() => {
                animate();
            });
    </script>
</body>
</html>