@using Feane.ViewModels.Appaeareance
@model List<AppeareanceGetVM>

<div class="container">
    <div class="row">

        <div class="col-2 mb-3">
            <a class="btn btn-success" asp-action="Create">
                Create
            </a>
        </div>

        <table class="table">
            <thead>
                <tr>
                    <th scope="col">Id</th>
                    <th scope="col">Title</th>
                    <th scope="col">Image</th>
                    <th scope="col">Description</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td>@product.Id</td>

                        <td>@product.Title</td>

                        <td><img src="~/images/@product.ImageName" width="100" /></td>

                        <td>@product.Description</td>

                        <td>
                            <a asp-action="Update" asp-route-id="@product.Id" class="btn btn-warning">Update</a>
                            <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-danger">Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>
</div>