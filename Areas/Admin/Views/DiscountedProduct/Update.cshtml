@using Feane.ViewModels.DiscountedProduct
@model DiscountedProductUpdateVM

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <form method="post" asp-action="Update">

                <input type="hidden" asp-for="Id" />

                <div class="form-group mb-3">
                    <label asp-for="DishId" class="form-label">Select Dish (Menu Product)</label>
                    <select asp-for="DishId" class="form-control" asp-items="@(new SelectList(ViewBag.Dishes, "Id", "Name"))">
                        <option value="" disabled>-- Choose a Dish --</option>
                    </select>
                    <span asp-validation-for="DishId" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Percentage" class="form-label">Discount Percentage (%)</label>
                    <input type="number" asp-for="Percentage" class="form-control" placeholder="Enter Percentage" />
                    <span asp-validation-for="Percentage" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary mt-3">Save Changes</button>
            </form>
        </div>
    </div>
</div>